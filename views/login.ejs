<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
    <title>Librarian Login – NNM Library</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
    <style>
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        body{font-family:'Inter',sans-serif;min-height:100vh;
          background:linear-gradient(135deg,#dbeafe 0%,#f0fdf4 55%,#fef9c3 100%);
          display:flex;align-items:center;justify-content:center;padding:20px}
        .card{background:#fff;border-radius:22px;padding:46px 40px 38px;
          width:100%;max-width:420px;box-shadow:0 12px 48px rgba(0,0,0,0.11);
          border:1px solid #e2e8f0}
        .logo{text-align:center;margin-bottom:28px}
        .logo-icon{font-size:2.8rem;display:block;margin-bottom:8px}
        .logo h1{font-size:1.45rem;font-weight:800;color:#0f172a}
        .logo p{font-size:.82rem;color:#64748b;margin-top:4px}
        .error{background:#fef2f2;border:1px solid #fecaca;border-radius:9px;
          padding:10px 14px;font-size:.86rem;color:#dc2626;margin-bottom:16px;text-align:center}
        label{display:block;font-size:.78rem;font-weight:700;color:#475569;
          margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px}
        .input-wrap{position:relative;margin-bottom:14px}
        .input-wrap span{position:absolute;left:13px;top:50%;transform:translateY(-50%)}
        input{width:100%;padding:13px 14px 13px 38px;border:1.5px solid #cbd5e1;
          border-radius:11px;font-size:.95rem;color:#0f172a;background:#f8fafc;
          outline:none;transition:border-color .2s,box-shadow .2s}
        input::placeholder{color:#94a3b8}
        input:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.12);background:#fff}
        .btn{width:100%;padding:13px;background:linear-gradient(135deg,#3b82f6,#6366f1);
          border:none;border-radius:11px;color:#fff;font-size:.97rem;font-weight:700;
          cursor:pointer;transition:opacity .2s;margin-top:4px}
        .btn:hover{opacity:.87}
        .back{display:block;text-align:center;margin-top:18px;font-size:.83rem;
          color:#64748b;text-decoration:none;transition:color .2s}
        .back:hover{color:#3b82f6}
    </style>
</head>
<body>
<div class="card">
    <div class="logo">
        <span class="logo-icon">🔑</span>
        <h1>Librarian Login</h1>
        <p>NNM Institute of Technology Library</p>
    </div>

    <% if(error){ %>
        <div class="error">⚠ <%= error %></div>
    <% } %>

    <form action="/librarian/login" method="POST">
        <label>Email Address</label>
        <div class="input-wrap">
            <span>✉️</span>
            <input type="email" name="email" placeholder="admin@gmail.com" required/>
        </div>

        <label>Password</label>
        <div class="input-wrap">
            <span>🔒</span>
            <input type="password" name="password" placeholder="••••••••" required/>
        </div>

        <button type="submit" class="btn">→  Sign In</button>
    </form>

    <a href="/" class="back">← Back to Student Portal</a>
</div>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
    <title>Edit Book – NNM Library</title>
    <link rel="stylesheet" href="/style.css"/>
</head>
<body>

<%- include('partials/sidebar', { active: 'books' }) %>

<div class="main">
    <div class="page-top">
        <div>
            <h1>Edit Book</h1>
            <p class="sub">Book ID: <strong>#<%= book.id %></strong></p>
        </div>
        <a href="/books" class="btn-outline-sm">← Back to Books</a>
    </div>

    <div class="form-card">
        <form action="/books/edit/<%= book.id %>" method="POST">

            <div class="form-row">
                <div class="form-group">
                    <label>Book Title <span class="req">*</span></label>
                    <input type="text" name="title" value="<%= book.title %>" required/>
                </div>
                <div class="form-group">
                    <label>Author Name <span class="req">*</span></label>
                    <input type="text" name="author" value="<%= book.author %>" required/>
                </div>
            </div>

            <div class="form-group" style="max-width:200px">
                <label>Quantity <span class="req">*</span></label>
                <input type="number" name="quantity" value="<%= book.quantity %>" required min="0"/>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary">💾 Save Changes</button>
                <a href="/books" class="btn-ghost">Cancel</a>
            </div>

        </form>
    </div>
</div>
</body>
</html>
